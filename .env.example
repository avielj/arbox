# Arbox credentials
ARBOX_EMAIL=your_email@example.com
ARBOX_PASSWORD=your_password

# Telegram bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Signup settings
SIGNUP_HOUR=08:00
BOX_ID=70
DAYS_AHEAD=12

# Class mapping (day=ClassName, comma separated)
# Use day names: Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday
CLASS_FRIDAY="Fuck You Friday"
CLASS_DEFAULT="CrossFit"

# Skip days (comma separated, e.g., Saturday)
SKIP_DAYS=Saturday
